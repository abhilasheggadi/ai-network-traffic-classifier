# AI Network Traffic Classifier - Environment Configuration
# Copy this file to .env and update values for your environment
# NOTE: Security-sensitive values (API_KEY, etc.) should NOT be committed to git

# ==================== API Configuration ====================
# API Host (use 0.0.0.0 for Docker/production)
API_HOST=0.0.0.0

# API Port
API_PORT=8000

# API Key for authentication (CHANGE THIS IN PRODUCTION!)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=dev-key-change-in-production

# Enable hot reload in development (disable in production)
API_RELOAD=false

# API log level (debug, info, warning, error, critical)
API_LOG_LEVEL=info

# ==================== Security Configuration ====================
# CORS allowed origins (comma-separated)
# For development: http://localhost:8501,http://127.0.0.1:8501
# For production: https://yourdomain.com
CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# ==================== Logging Configuration ====================
# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log directory path (will be created if not exists)
LOG_DIR=logs

# ==================== Application Mode ====================
# Demo mode (use sample data for testing)
DEMO_MODE=true

# ==================== Model Configuration ====================
# Path to trained model file
MODEL_PATH=model/saved_models/traffic_classifier.joblib

# Path to encoder file
ENCODER_PATH=model/saved_models/label_encoder.joblib

# Path to metadata file
METADATA_PATH=model/saved_models/metadata.json

# ==================== Data Configuration ====================
# Data directory
DATA_DIR=data

# ==================== Development Settings ====================
# Set to 'True' for development, 'False' for production
DEBUG=False

# Python environment (development, testing, production)
ENVIRONMENT=production
