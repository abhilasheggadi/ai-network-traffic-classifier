# Environment Configuration
# Copy this file to .env and update values as needed

# API Configuration
API_HOST=127.0.0.1
API_PORT=8000
API_RELOAD=True
API_LOG_LEVEL=error

# Dashboard Configuration
DASHBOARD_PORT=8501
DASHBOARD_HOST=localhost

# Logging
LOG_LEVEL=INFO

# Database (Optional)
DB_URL=sqlite:///data/app.db
USE_DATABASE=False

# CORS Settings
CORS_ORIGINS=*
CORS_CREDENTIALS=True
CORS_METHODS=*
CORS_HEADERS=*

# Demo Mode (Uses synthetic data)
DEMO_MODE=True
